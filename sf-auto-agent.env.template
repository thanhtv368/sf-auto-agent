# Copy to ~/.claude/sf-auto-agent.env and chmod 600.

# --- Jira (task tracking) ---
JIRA_BASE_URL=https://your-tenant.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=<atlassian-api-token>
# Optional, only used by cloud-id-scoped endpoints (most setups don't need it):
JIRA_CLOUD_ID=

# --- Salesforce DevHub (used to spin up per-branch scratch orgs) ---
# The implementation pipeline uses the `sf` CLI. You must already have a
# DevHub authenticated on this machine, typically:
#   sf org login web --alias DevHub --set-default-dev-hub
# The skill only needs the alias name; tokens are managed by the sf CLI.
SF_DEVHUB_ALIAS=DevHub

# --- GitHub fallback ---
# Optional default if a project config omits github.repo.
DEFAULT_GITHUB_REPO=org/repo

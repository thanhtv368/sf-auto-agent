# Copy to ~/.claude/sf-auto-agent.env and chmod 600.
# Salesforce Connected App with OAuth (username-password flow) enabled.

SF_LOGIN_URL=https://login.salesforce.com
# For sandbox use:  https://test.salesforce.com

SF_CLIENT_ID=<connected-app-consumer-key>
SF_CLIENT_SECRET=<connected-app-consumer-secret>
SF_USERNAME=user@example.com
# IMPORTANT: append the user's security token to the password (no separator).
# Reset security token: Salesforce Setup → My Personal Information → Reset My Security Token.
SF_PASSWORD=<password><security-token>

# Optional fallback if a project config omits github.repo
DEFAULT_GITHUB_REPO=org/repo
